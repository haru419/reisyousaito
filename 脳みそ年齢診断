<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>脳みそ年齢診断</title>

<style>
body{
margin:0;
font-family:'Segoe UI', sans-serif;
background:linear-gradient(135deg,#0f0f0f,#1a1a2e);
color:white;
display:flex;
justify-content:center;
align-items:center;
min-height:100vh;
}

.card{
width:90%;
max-width:520px;
background:rgba(255,255,255,0.05);
backdrop-filter:blur(12px);
padding:30px;
border-radius:20px;
box-shadow:0 0 40px rgba(255,0,150,0.25);
transition:0.4s;
animation:fadeIn 0.6s ease;
}

.card:hover{
box-shadow:0 0 70px rgba(255,0,150,0.45);
}

h1{
text-align:center;
margin-bottom:15px;
}

.progress{
height:6px;
background:#333;
border-radius:10px;
overflow:hidden;
margin-bottom:20px;
}

.bar{
height:100%;
width:0%;
background:linear-gradient(90deg,#ff4ecd,#ff0080);
transition:0.4s;
}

.question{
margin-bottom:20px;
min-height:60px;
font-size:18px;
}

button{
width:100%;
padding:13px;
margin:8px 0;
border-radius:12px;
border:1px solid #444;
background:#1f1f1f;
color:white;
cursor:pointer;
transition:0.25s;
font-size:14px;
}

button:hover{
background:#ff0080;
transform:scale(1.05);
box-shadow:0 0 15px #ff0080,
           0 0 35px #ff0080;
}

#loading{
display:none;
text-align:center;
}

.loader{
width:80px;
height:80px;
border:8px solid #333;
border-top:8px solid #ff0080;
border-radius:50%;
margin:20px auto;
animation:spin 1s linear infinite;
}

@keyframes spin{
0%{transform:rotate(0);}
100%{transform:rotate(360deg);}
}

#result{
display:none;
text-align:center;
}

@keyframes fadeIn{
from{opacity:0; transform:translateY(10px);}
to{opacity:1; transform:translateY(0);}
}
</style>
</head>

<body>

<div class="card">
<h1>🧠 脳みそ年齢診断</h1>

<div class="progress">
<div class="bar" id="bar"></div>
</div>

<div id="quiz">
<div class="question" id="question"></div>
<div id="answers"></div>
</div>

<div id="loading">
<div class="loader"></div>
<p>脳年齢を解析中...</p>
</div>

<div id="result">
<h2 id="resultTitle"></h2>
<p id="resultComment"></p>
<button onclick="restart()">もう一度診断</button>
</div>

</div>

<script>

const questions = [

{
q:"休日の朝は？",
choices:[
{text:"昼まで寝る", point:3},
{text:"スマホを見る", point:2},
{text:"すぐ行動する", point:1},
{text:"早起きして散歩", point:0}
]
},

{
q:"新しいアプリが出たら？",
choices:[
{text:"即インストール", point:3},
{text:"少し気になる", point:2},
{text:"必要なら使う", point:1},
{text:"興味ない", point:0}
]
},

{
q:"動画を見る時は？",
choices:[
{text:"倍速視聴", point:3},
{text:"スキップ多め", point:2},
{text:"普通に見る", point:1},
{text:"最後までじっくり", point:0}
]
},

{
q:"最近よく使う言葉は？",
choices:[
{text:"それな", point:3},
{text:"草", point:2},
{text:"まあ普通", point:1},
{text:"最近の言葉が分からない", point:0}
]
},

{
q:"集中力は？",
choices:[
{text:"5秒で消える", point:3},
{text:"かなり短い", point:2},
{text:"普通", point:1},
{text:"長時間集中できる", point:0}
]
},

{
q:"通知が来たら？",
choices:[
{text:"即見る", point:3},
{text:"気になってしまう", point:2},
{text:"後で見る", point:1},
{text:"放置できる", point:0}
]
},

{
q:"ネットミームを見た時は？",
choices:[
{text:"全部わかる", point:3},
{text:"大体わかる", point:2},
{text:"少しわかる", point:1},
{text:"全然わからない", point:0}
]
},

{
q:"昔のゲームと今のゲームなら？",
choices:[
{text:"今のゲーム最高", point:3},
{text:"どっちも好き", point:2},
{text:"昔の方が好き", point:1},
{text:"ゲームしない", point:0}
]
}

];

let current=0;
let score=0;

const q=document.getElementById("question");
const ans=document.getElementById("answers");
const bar=document.getElementById("bar");

function load(){

q.textContent = questions[current].q;
ans.innerHTML = "";

questions[current].choices.forEach(c=>{

let btn=document.createElement("button");

btn.textContent=c.text;

btn.onclick=()=>select(c.point);

ans.appendChild(btn);

});

bar.style.width=(current/questions.length*100)+"%";
}

function select(p){

score+=p;
current++;

if(current<questions.length){
load();
}else{
showLoading();
}

}

function showLoading(){

document.getElementById("quiz").style.display="none";
document.getElementById("loading").style.display="block";

setTimeout(()=>{

document.getElementById("loading").style.display="none";
showResult();

},1500);

}

function showResult(){

document.getElementById("result").style.display="block";
bar.style.width="100%";

let title="",comment="";

if(score<=4){

title="👴 脳年齢 80歳";
comment="落ち着きと貫禄がすごい。ネット文化に流されない最強タイプ。";

}else if(score<=10){

title="🧓 脳年齢 50歳";
comment="かなり冷静派。流行にもそこまで振り回されない。";

}else if(score<=16){

title="🧑 脳年齢 25歳";
comment="現代人らしいバランス型。SNSもネットも適度に楽しめる。";

}else{

title="👶 脳年齢 5歳";
comment="刺激とテンションで生きているインターネット生命体。";

}

document.getElementById("resultTitle").textContent=title;
document.getElementById("resultComment").textContent=comment;

}

function restart(){

current=0;
score=0;

document.getElementById("quiz").style.display="block";
document.getElementById("result").style.display="none";

load();

}

load();

</script>

</body>
</html>
